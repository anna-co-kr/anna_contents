# Prompt Studio v0.5 — 환경변수 예시
# 실제 값은 .env.local (gitignored) 또는 Vercel Project Settings에서 관리.
# 2026-04-24 B 재설계 이후: Anthropic·Voyage API 키 불필요 (월 운영비 $0).

# ─── Supabase (필수) ─────────────────────────────────────────────────────
# dashboard: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# publishable = 레거시 ANON_KEY 대체 신규 이름 (pk_live_... / sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
# 서버 전용 (Service Role) — 클라이언트 노출 절대 금지. Vercel에선 "sensitive" 토글.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_KEY

# ─── Slack 알림 (선택, 로컬 개발 전용) ──────────────────────────────────
# .claude/hooks/*.sh가 Claude Code 세션 이벤트를 이 채널로 쏨.
# Vercel에는 넣지 말 것 (Claude Code 훅은 로컬 전용).
SLACK_WEBHOOK_URL=

# ─── Playwright E2E 테스트 계정 (로컬 테스트 실행 시) ────────────────────
# Vercel에는 넣지 말 것. 테스트는 로컬·CI에서만 실행.
TEST_EMAIL=
TEST_PASSWORD=
