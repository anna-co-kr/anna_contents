# Prompt Studio v0.5 환경변수 템플릿
# 복사: cp .env.example .env.local  (실제 값은 .env.local에만, gitignore 보호됨)
#
# 이 제품은 외부 AI API를 호출하지 않습니다 (Claude Code CLI 컴패니언 모델).
# AI 보조는 안나의 Claude Code CLI(MAX 구독)에서 수행. 월 운영비 $0.

# --- Supabase ---
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# 서버 전용 (Route Handler·스크립트에서만, 클라이언트 번들 유입 금지)
SUPABASE_SERVICE_ROLE_KEY=

# --- Slack 훅 알림 (선택) ---
# SLACK_WEBHOOK_URL=
